# Google Analytics 4 Measurement ID (public identifier, safe to expose)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Visitor-count badge (/api/visitors) — server-side, keep secret.
# GA_PROPERTY_ID: numeric GA4 property id (the "p" number in the GA URL).
# Preferred auth = OAuth as the property owner (works around Google's bug that
# blocks NEW service accounts from being added to GA4 since 2025-04-23):
GA_PROPERTY_ID=532067997
GA_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GA_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GA_OAUTH_REFRESH_TOKEN=your-oauth-refresh-token
# Fallback auth (service-account JWT) — only works for SAs created before the
# bug. base64 of the key JSON:
# GA_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json

SMTP_HOST=your-smtp-host
SMTP_PORT=your-smtp-port
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=your-smtp-from
SMTP_TO=your-smtp-to
SMTP_SECURE=false
